# Liirat Economic Dashboard Configuration

# Financial Data API Configuration
# Choose one of: "finnhub", "trading-economics", "marketaux"
NEXT_PUBLIC_FINANCIAL_API_PROVIDER=finnhub

# API Key for your chosen provider
# Get your API key from:
# - Finnhub: https://finnhub.io/register
# - Trading Economics: https://tradingeconomics.com/api
# - Marketaux: https://www.marketaux.com/account/register
NEXT_PUBLIC_FINANCIAL_API_KEY=your_api_key_here

# Base URL for the API (provider-specific)
# Finnhub: https://finnhub.io/api/v1
# Trading Economics: https://api.tradingeconomics.com
# Marketaux: https://api.marketaux.com
NEXT_PUBLIC_FINANCIAL_API_BASE_URL=https://finnhub.io/api/v1

# OpenAI Configuration (for AI features)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: WebSocket configuration for real-time updates
NEXT_PUBLIC_WEBSOCKET_URL=wss://ws.finnhub.io

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id_here
